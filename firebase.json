{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/.git",
      "**/.git/**",
      ".git",
      ".gitignore",
      "**/node_modules/**",
      "**/*.md",
      "tests/**",
      "**/*.sh",
      "package*.json",
      "**/*.txt",
      "debug-*.js",
      "test-*.js"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

