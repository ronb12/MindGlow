rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // User profile
      match /profile/{document=**} {
        allow read, write: if isOwner(userId);
      }
      
      // User statistics
      match /stats/{document=**} {
        allow read, write: if isOwner(userId);
      }
      
      // Meditation sessions history
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
      
      // Mood tracking
      match /moods/{moodId} {
        allow read, write: if isOwner(userId);
      }
      
      // Habits
      match /habits/{habitId} {
        allow read, write: if isOwner(userId);
      }
      
      // Journal entries
      match /journal/{entryId} {
        allow read, write: if isOwner(userId);
      }
      
      // Gratitude entries
      match /gratitude/{entryId} {
        allow read, write: if isOwner(userId);
      }
      
      // Personal notes
      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }
      
      // Affirmations
      match /affirmations/{affirmationId} {
        allow read, write: if isOwner(userId);
      }
      
      // Water intake tracking
      match /water/{trackingId} {
        allow read, write: if isOwner(userId);
      }
      
      // Sleep tracking
      match /sleep/{sleepId} {
        allow read, write: if isOwner(userId);
      }
      
      // Screen time
      match /screenTime/{timeId} {
        allow read, write: if isOwner(userId);
      }

      // Saved cart (syncs across devices)
      match /cart/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Friends collection - users can read friends and write their own connections
    match /friends/{friendshipId} {
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         resource.data.friendId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Community posts - authenticated users can read all, write their own
    match /community/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Group meditation sessions - read all, admins can write
    match /groupSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Weekly challenges - read all, admins can write
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Leaderboard - read all, system writes
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side functions can write
    }
    
    // Store: products - all authenticated users can read; only store owner can write
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
    
    // Store: orders - customers create; owner can read/update all; users can read their own
    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner');
      allow update, delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
    
    // Store: settings (tax, shipping) - owner write, authenticated read
    match /storeSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
    
    // Store: promo codes - authenticated read (to apply), owner write
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    // Store: customers (owner-managed list; add/edit manually)
    match /customers/{customerId} {
      allow read, write: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
  }
}

